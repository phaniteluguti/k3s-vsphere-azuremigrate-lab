# Copy this file to terraform.tfvars and fill in your environment values.
# terraform.tfvars is gitignored so real credentials never get committed.

# --- vCenter connection ---
# NOTE: do NOT put the password here. It is supplied at runtime via the
# TF_VAR_vsphere_password environment variable (you are prompted by `make up`
# / `make down`, or `scripts/tf.sh`). This keeps the secret off disk entirely.
vsphere_server       = "vcenter.lab.local"
vsphere_user         = "administrator@vsphere.local"
allow_unverified_ssl = true

# --- vSphere placement ---
datacenter    = "Datacenter"
cluster       = "Cluster"
resource_pool = "Cluster/Resources"
datastore     = "datastore1"
network       = "VM Network"
vm_folder     = ""
template_name = "ubuntu-24.04-template"

# --- Cluster shape ---
cluster_name = "k3s-lab"
agent_count  = 2

# --- Node IP allocation ---
# "dhcp"  = let the port group / network assign addresses (needs working DHCP).
# "static" = assign sequential addresses from node_subnet_cidr:
#            server -> node_ip_start, agent-1 -> +1, agent-2 -> +2, ...
ip_allocation    = "static"
node_subnet_cidr = "10.35.1.0/24"
node_ip_start    = 20
node_gateway     = "" # blank = first host of node_subnet_cidr (e.g. 10.35.1.1)
node_dns         = ["1.1.1.1", "8.8.8.8"]

# --- Guest SSH access (paste the contents of your public key) ---
ssh_public_key = "ssh-ed25519 AAAA... user@host"
